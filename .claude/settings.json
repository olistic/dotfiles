{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(* --help *)",
      "Bash(* --version)",
      "Bash(brew info *)",
      "Bash(brew list *)",
      "Bash(brew outdated *)",
      "Bash(brew search *)",
      "Bash(env)",
      "Bash(file *)",
      "Bash(gh issue view *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git remote -v)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(git status *)",
      "Bash(git tag *)",
      "Bash(ls *)",
      "Bash(man *)",
      "Bash(npm ls *)",
      "Bash(npm outdated *)",
      "Bash(npm run build *)",
      "Bash(npm run lint *)",
      "Bash(npm run test *)",
      "Bash(npm test *)",
      "Bash(npm view *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier --check *)",
      "Bash(npx tsc --noEmit *)",
      "Bash(pnpm ls *)",
      "Bash(pnpm outdated *)",
      "Bash(pnpm run build *)",
      "Bash(pnpm run lint *)",
      "Bash(pnpm run test *)",
      "Bash(pnpm test *)",
      "Bash(pnpm view *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(yarn info *)",
      "Bash(yarn list *)",
      "Bash(yarn outdated *)",
      "Bash(yarn run build *)",
      "Bash(yarn run lint *)",
      "Bash(yarn run test *)",
      "Bash(yarn test *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "model": "opus",
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "fastMode": true,
  "teammateMode": "tmux",
  "voiceEnabled": true
}
