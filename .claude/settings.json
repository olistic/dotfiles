{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(* --help:*)",
      "Bash(* --version)",
      "Bash(brew info:*)",
      "Bash(brew list:*)",
      "Bash(brew outdated:*)",
      "Bash(brew search:*)",
      "Bash(env)",
      "Bash(file:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh label list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh search:*)",
      "Bash(gh status:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git checkout -b:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git remote -v)",
      "Bash(git show:*)",
      "Bash(git stash list)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(git tag:*)",
      "Bash(git worktree:*)",
      "Bash(ls:*)",
      "Bash(man:*)",
      "Bash(npm i:*)",
      "Bash(npm install:*)",
      "Bash(npm ls:*)",
      "Bash(npm outdated:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm test:*)",
      "Bash(npm view:*)",
      "Bash(npx biome:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier --check:*)",
      "Bash(npx tsc --noEmit:*)",
      "Bash(npx vitest:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm biome:*)",
      "Bash(pnpm eslint:*)",
      "Bash(pnpm i:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm ls:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm prettier --check:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run test:*)",
      "Bash(pnpm run typecheck:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm tsc --noEmit:*)",
      "Bash(pnpm view:*)",
      "Bash(pnpm vitest:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(yarn add:*)",
      "Bash(yarn info:*)",
      "Bash(yarn install:*)",
      "Bash(yarn list:*)",
      "Bash(yarn outdated:*)",
      "Bash(yarn run build:*)",
      "Bash(yarn run lint:*)",
      "Bash(yarn run test:*)",
      "Bash(yarn run typecheck:*)",
      "Bash(yarn test:*)",
      "Bash(bun add:*)",
      "Bash(bun i:*)",
      "Bash(bun install:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(sudo:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(*| bash)",
      "Bash(*| sh)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.ssh/**)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Read(~/Library/Keychains/**)"
    ]
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '\"command\"\\s*:\\s*\"rm\\s+-(rf|fr)\\s'; then echo 'Use trash instead of rm -rf' >&2; exit 2; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '\"command\"\\s*:\\s*\"git\\s+push\\s+.*\\b(main|master)\\b'; then echo 'Use feature branches — do not push directly to main/master' >&2; exit 2; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "effortLevel": "high",
  "teammateMode": "auto"
}
